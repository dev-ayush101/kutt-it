    {
      "name": "Redirect",
      "description": "R1 has followRedirects disabled to assert the 302 directly.",
      "item": [
        {
          "name": "R1 - Valid Code",
          "protocolProfileBehavior": { "followRedirects": false },
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/r/{{shortCode}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 302', () => pm.response.to.have.status(302));",
            "pm.test('Location header present', () => pm.expect(pm.response.headers.get('Location')).to.be.a('string'));"
          ]}}]
        },
        {
          "name": "R2 - Invalid Code",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/r/doesnotexist99999"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 409', () => pm.response.to.have.status(409));",
            "pm.test('Error message', () => pm.expect(pm.response.text()).to.include('URL Not Found'));"
          ]}}]
        },

{
  "info": {
    "name": "Kutt-it API - Complete Test Suite",
    "description": "Run the [Setup] folder first in order. Collection variables are auto-populated by test scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:8080" },
    { "key": "token",          "value": "" },
    { "key": "token2",         "value": "" },
    { "key": "email1",         "value": "user1@kuttit.test" },
    { "key": "email2",         "value": "user2@kuttit.test" },
    { "key": "shortCode",      "value": "" },
    { "key": "anonShortCode",  "value": "" },
    { "key": "expiredCode",              "value": "" },
    { "key": "expiredCodeForRedirect",   "value": "" },
    { "key": "taggedCode",     "value": "" },
    { "key": "deleteCode",     "value": "" },
    { "key": "preDeletedCode", "value": "" },
    { "key": "updateCode",     "value": "" },
    { "key": "testAlias",      "value": "" },
    { "key": "newAlias",       "value": "" },
    { "key": "uniqueEmail",    "value": "" }
  ],
  "item": [
    {
      "name": "[Setup] Initialize Test Data",
      "description": "Run all items in this folder in order before running any other tests.",
      "item": [
        {
          "name": "S1 - Register User 1",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\"username\":\"user1\",\"email\":\"{{email1}}\",\"password\":\"Password123!\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "    pm.test('S1: Registered User 1', () => pm.response.to.have.status(200));",
            "    pm.collectionVariables.set('token', pm.response.json().token);",
            "} else {",
            "    pm.sendRequest({",
            "        url: pm.collectionVariables.get('baseUrl') + '/api/auth/login',",
            "        method: 'POST',",
            "        header: [{ key: 'Content-Type', value: 'application/json' }],",
            "        body: { mode: 'raw', raw: JSON.stringify({ email: pm.collectionVariables.get('email1'), password: 'Password123!' }) }",
            "    }, (err, res) => {",
            "        pm.test('S1: Login fallback for User 1', () => pm.expect(res.code).to.equal(200));",
            "        pm.collectionVariables.set('token', res.json().token);",
            "    });",
            "}"
          ]}}]
        },
        {
          "name": "S2 - Register User 2",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\"username\":\"user2\",\"email\":\"{{email2}}\",\"password\":\"Password123!\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "if (pm.response.code === 200) {",
            "    pm.test('S2: Registered User 2', () => pm.response.to.have.status(200));",
            "    pm.collectionVariables.set('token2', pm.response.json().token);",
            "} else {",
            "    pm.sendRequest({",
            "        url: pm.collectionVariables.get('baseUrl') + '/api/auth/login',",
            "        method: 'POST',",
            "        header: [{ key: 'Content-Type', value: 'application/json' }],",
            "        body: { mode: 'raw', raw: JSON.stringify({ email: pm.collectionVariables.get('email2'), password: 'Password123!' }) }",
            "    }, (err, res) => {",
            "        pm.test('S2: Login fallback for User 2', () => pm.expect(res.code).to.equal(200));",
            "        pm.collectionVariables.set('token2', res.json().token);",
            "    });",
            "}"
          ]}}]
        },
        {
          "name": "S3 - Create URL for User 1",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/user1-main\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('shortCode', pm.response.json().shortCode);"
          ]}}]
        },
        {
          "name": "S4 - Create Anonymous URL",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/anonymous\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('anonShortCode', pm.response.json().shortCode);"
          ]}}]
        },
        {
          "name": "S5 - Create Expired URL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/expired\",\"expirationDate\":\"2020-01-01T00:00:00\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('expiredCode', pm.response.json().shortCode);"
          ]}}]
        },
        {
          "name": "S5b - Create Expired URL for Redirect Test",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/expired-redirect\",\"expirationDate\":\"2020-01-01T00:00:00\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('expiredCodeForRedirect', pm.response.json().shortCode);"
          ]}}]
        },
        {
          "name": "S6 - Create Tagged URL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/tagged\",\"tags\":[\"social\",\"work\"]}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('taggedCode', pm.response.json().shortCode);"
          ]}}]
        },
        {
          "name": "S7 - Create URL for Delete Tests",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/to-delete\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('deleteCode', pm.response.json().shortCode);"
          ]}}]
        },
        {
          "name": "S8a - Create URL to Pre-Delete",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/pre-deleted\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('preDeletedCode', pm.response.json().shortCode);"
          ]}}]
        },
        {
          "name": "S8b - Delete the Pre-Delete URL",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/links/{{preDeletedCode}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "S9 - Create URL for Update Tests",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/to-update\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.collectionVariables.set('updateCode', pm.response.json().shortCode);"
          ]}}]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "A1 - Register Success",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "pm.collectionVariables.set('uniqueEmail', 'test_' + Date.now() + '@kuttit.test');"
            ]}},
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('Has token', () => pm.expect(j.token).to.be.a('string'));",
              "pm.test('Has email', () => pm.expect(j.email).to.eql(pm.collectionVariables.get('uniqueEmail')));",
              "pm.test('Has username', () => pm.expect(j.username).to.eql('tempuser'));"
            ]}}
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\"username\":\"tempuser\",\"email\":\"{{uniqueEmail}}\",\"password\":\"Password123!\"}" }
          }
        },
        {
          "name": "A2 - Register Duplicate Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\"username\":\"dupe\",\"email\":\"{{email1}}\",\"password\":\"Password123!\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Rejects duplicate email', () => pm.expect(pm.response.code).to.not.eql(200));",
            "pm.test('Error mentions email', () => pm.expect(pm.response.text()).to.include('Email already in use'));"
          ]}}]
        },
        {
          "name": "A3 - Register Missing Fields",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\"email\":\"incomplete@kuttit.test\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "A4 - Register Invalid Email Format",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": { "mode": "raw", "raw": "{\"username\":\"u\",\"email\":\"notanemail\",\"password\":\"Password123!\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));"
          ]}}]
        },
        {
          "name": "A5 - Login Success",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\":\"{{email1}}\",\"password\":\"Password123!\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.test('Has token', () => pm.expect(j.token).to.be.a('string'));",
            "pm.test('Email matches', () => pm.expect(j.email).to.eql(pm.collectionVariables.get('email1')));",
            "pm.collectionVariables.set('token', j.token);"
          ]}}]
        },
        {
          "name": "A6 - Login Wrong Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\":\"{{email1}}\",\"password\":\"WrongPassword!\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Rejects wrong password', () => pm.expect(pm.response.code).to.not.eql(200));",
            "pm.test('Error message', () => pm.expect(pm.response.text()).to.include('Invalid email or password'));"
          ]}}]
        },
        {
          "name": "A7 - Login Unknown Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\":\"nobody@kuttit.test\",\"password\":\"Password123!\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Rejects unknown user', () => pm.expect(pm.response.code).to.not.eql(200));",
            "pm.test('Same error as wrong password', () => pm.expect(pm.response.text()).to.include('Invalid email or password'));"
          ]}}]
        },
        {
          "name": "A8 - Login Missing Fields",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));"
          ]}}]
        }
      ]
    },
    {
      "name": "Shorten URL",
      "item": [
        {
          "name": "SH1 - Shorten Anonymous",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/anon-shorten\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const j = pm.response.json();",
            "pm.test('Has shortCode', () => pm.expect(j.shortCode).to.be.a('string'));",
            "pm.test('shortUrl contains shortCode', () => pm.expect(j.shortUrl).to.include(j.shortCode));"
          ]}}]
        },
        {
          "name": "SH2 - Shorten Authenticated",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/auth-shorten\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [

            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/custom2\",\"customAlias\":\"{{testAlias}}\"}" }
          },

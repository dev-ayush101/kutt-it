          ]}}]
        },
        {
          "name": "SH3 - Custom Alias New",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "pm.collectionVariables.set('testAlias', 'alias-' + Date.now().toString().slice(-6));"
            ]}},
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('shortCode matches alias', () => pm.expect(pm.response.json().shortCode).to.eql(pm.collectionVariables.get('testAlias')));"
            ]}}
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/custom\",\"customAlias\":\"{{testAlias}}\"}" }
          }
        },

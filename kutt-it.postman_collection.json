      "name": "Rate Limiting (Manual)",
      "description": "Restart the app before each run — buckets are in-memory and reset on restart.\n\nRL1 (Anonymous): Send 11 times with no token from the same IP. The 11th returns 429.\nRL2 (Authenticated): Send 121 times with the same token. The 121st returns 429.\nNote: POST /api/shorten/bulk is never rate-limited — the URI check in RateLimitFilter is an exact match on /api/shorten.",
      "item": [
        {
          "name": "RL1 - Anonymous Rate Limit",
          "description": "Restart app first. Send this 11 times. The 11th should return 429.",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/shorten",
            "body": { "mode": "raw", "raw": "{\"url\":\"https://example.com/rate-test\"}" }
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('200 or 429', () => pm.expect(pm.response.code).to.be.oneOf([200, 429]));",
            "if (pm.response.code === 429) {",
            "  pm.test('Rate limit message', () => pm.expect(pm.response.text()).to.include('Rate limit exceeded'));",
            "}"
          ]}}]
        },
        {
          "name": "RL2 - Authenticated Rate Limit",
          "description": "Restart app first. Send this 121 times with token. The 121st should return 429.",
          "request": {
            "method": "POST",
